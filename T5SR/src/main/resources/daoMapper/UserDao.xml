<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.t5sr.dao.daoMapper.UserDao">

    <resultMap id="UserResultMap" type="org.example.t5sr.model.User">
        <id property="login" column="login"/>
        <result property="password" column="password"/>
        <result property="email" column="email"/>
        <result property="surname" column="surname"/>
        <result property="name" column="name"/>
        <result property="patronymic" column="patronymic"/>
        <result property="birthday" column="birthday"/>
        <collection property="roles" column="login"
                    ofType="org.example.t5sr.model.Role"
                    select="org.example.t5sr.dao.daoMapper.RoleDao.findRolesByUserLogin"/>
    </resultMap>

    <select id="findAll" resultMap="UserResultMap">
        SELECT * FROM users
    </select>

    <select id="findByLogin" resultMap="UserResultMap">
        SELECT * FROM users WHERE login = #{login}
    </select>

    <insert id="insert">
        INSERT INTO users (login, password, email, surname, name, patronymic, birthday)
        VALUES (#{login}, #{password}, #{email}, #{surname}, #{name}, #{patronymic}, #{birthday})
    </insert>

    <update id="update">
        UPDATE users
        SET email = #{email},
            surname = #{surname},
            name = #{name},
            patronymic = #{patronymic},
            birthday = #{birthday}
        WHERE login = #{login}
    </update>

    <update id="updatePassword">
        UPDATE users SET password = #{newPassword} WHERE login = #{login}
    </update>

    <delete id="delete">
        DELETE FROM users WHERE login = #{login}
    </delete>

    <insert id="insertUserRole">
        INSERT INTO users_roles (user_login, role_id) VALUES (#{login}, #{roleId})
    </insert>

    <delete id="deleteUserRoles">
        DELETE FROM users_roles WHERE user_login = #{login}
    </delete>
</mapper>